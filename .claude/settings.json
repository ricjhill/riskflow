{
  "permissions": {
    "allow": [
      "Bash(uv run:*)",
      "Bash(uv sync:*)",
      "Bash(uv add:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git commit:*)",
      "Bash(git add:*)",
      "Bash(git push:*)",
      "Bash(git push)",
      "Bash(gh:*)",
      "Bash(docker compose:*)",
      "Bash(ls:*)",
      "Bash(ls)"
    ],
    "deny": [
      "Edit(uv.lock)",
      "Edit(.env)",
      "Bash(git push --force:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-commit.sh",
            "timeout": 120
          },
          {
            "type": "command",
            "command": ".claude/hooks/check-boundaries.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": ".claude/hooks/security-scan.sh",
            "timeout": 120
          },
          {
            "type": "command",
            "command": ".claude/hooks/enforce-create-pr.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": ".claude/hooks/check-runtime-deps.sh",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/protect-files.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-edit-lint.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-rename-check.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
