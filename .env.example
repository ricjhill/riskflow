# Required: Groq API key for SLM header mapping
# Get one at https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Optional: Redis URL for caching mapped results
# If missing, NullCache is used (SLM called on every request)
REDIS_URL=redis://localhost:6379

# Optional: Path to a single YAML schema file
# If set, only this schema is loaded (ignoring schemas/ directory)
# SCHEMA_PATH=schemas/standard_reinsurance.yaml

# Optional: Name of the default schema (when multiple are loaded)
# Must match the 'name' field in one of the YAML files in schemas/
# DEFAULT_SCHEMA=standard_reinsurance
# --- Scaling (optional, defaults are production-ready) ---
# Uncomment to override defaults. Useful for debugging or rollback.
# JOB_STORE=redis              # redis | memory
# JOB_TTL=86400                # Redis job expiry in seconds (default 24h)
# ASYNC_BACKEND=tasks          # tasks | background
# SLM_CONCURRENCY=3            # 0 = unlimited, N = max concurrent Groq calls
# LOG_LEVEL=INFO               # DEBUG for verbose concurrency diagnostics
